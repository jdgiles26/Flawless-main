# ============================================================
# Localization Environment Variable Template
# Copy .env.example to .env and modify as needed
#
# Key: All components run locally/in a private network, without relying on any cloud services
# ============================================================

# ————— LLM API（Local Ollama/vLLM/LocalAI） —————
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
LLM_AUTH_TYPE=api_key

# ————— Embedding —————
EMBEDDING_API_BASE=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text
KNOWLEDGE_RUNTIME_WRITE_ENABLED=true
KNOWLEDGE_EMBEDDING_ENABLED=false
KNOWLEDGE_STORE_PATH=/tmp/luxyai-knowledge-base.json

# ————— LangFuse（Self-hosted） —————
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ————— Unified Observability（Optional, supports existing organizational services） —————
PROMETHEUS_URL=
LOKI_URL=
TEMPO_URL=
GRAFANA_URL=

# ————— Multi-cluster and CMDB —————
CMDB_URL=
RANCHER_URL=
