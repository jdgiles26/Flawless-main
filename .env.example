# ============================================================
# 本地化环境变量模板
# cp .env.example .env  然后按需修改
#
# 关键：所有组件都在本地/私有网络运行，不依赖任何云服务
# ============================================================

# ---------- LLM API（本地 Ollama/vLLM/LocalAI） ----------
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
LLM_AUTH_TYPE=api_key

# ---------- Embedding ----------
EMBEDDING_API_BASE=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text
KNOWLEDGE_RUNTIME_WRITE_ENABLED=true
KNOWLEDGE_EMBEDDING_ENABLED=false
KNOWLEDGE_STORE_PATH=/tmp/luxyai-knowledge-base.json

# ---------- LangFuse（自托管） ----------
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ---------- 统一可观测（可选，支持组织现有服务） ----------
PROMETHEUS_URL=
LOKI_URL=
TEMPO_URL=
GRAFANA_URL=

# ---------- 多集群与 CMDB ----------
CMDB_URL=
RANCHER_URL=
RANCHER_TOKEN=
RANCHER_CLUSTER_IDS=all

# ---------- 云与基础设施适配器 ----------
# 只在这里放非敏感信息；CSI_STORAGE_AK/SK、VIRTUALIZATION_PLATFORM_TOKEN 等密钥应放 Kubernetes Secret。
CLOUD_ADAPTERS_JSON=[{"id":"generic-storage","provider":"csi-storage","display_name":"Generic CSI Storage","enabled":false,"capabilities":["storage","csi","pv-pvc","capacity","latency","topology"],"auth_mode":"secret-ref","regions":["example-region"],"inventory_scope":"storage-pool/cluster","safety_boundary":"read-only discovery + PVC/PV change approval"},{"id":"virtualization-platform","provider":"virtualization","display_name":"Virtualization Platform","enabled":false,"capabilities":["hci","virtualization","network","storage","security","topology"],"auth_mode":"secret-ref","regions":["example-dc"],"inventory_scope":"tenant/resource-pool","safety_boundary":"tenant token + high-risk approval"}]
CSI_STORAGE_ENDPOINT=
VIRTUALIZATION_PLATFORM_ENDPOINT=

# ---------- 协作通道（密钥应放 Kubernetes Secret，不要放 ConfigMap） ----------
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LARK_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
WECOM_WEBHOOK_URL=
OUTBOUND_WEBHOOK_URL=

# ---------- K8s 权限 ----------
# "all" = 全集群监控；指定 namespace 用逗号分隔如 "default,prod"
ALLOWED_NAMESPACES=all

# ---------- Healing Agent ----------
# 服务端总开关。false 时即使前端打开自动修复，也只做 dry-run。
AUTO_HEALING_ENABLED=false
HEALING_SCALE_DELTA=1
OPS_MUTATION_ENABLED=false
AUTONOMOUS_OPS_ENABLED=false
OPS_EVIDENCE_TIMEOUT_SECONDS=70
OPS_STEP_TIMEOUT_SECONDS=35
OPS_CHANGE_TIMEOUT_SECONDS=45
OPS_HEARTBEAT_SECONDS=5

# ---------- SLO / 错误预算 / 发布治理 ----------
SLO_DEFAULT_TARGET_PERCENT=99.9
SLO_DEFAULT_WINDOW_DAYS=30
RELIABILITY_STORE_PATH=/tmp/luxyai-reliability-state.json
EFFECTIVENESS_STORE_PATH=/tmp/luxyai-effectiveness-state.json
EFFECTIVENESS_STORE_FALLBACK_PATH=/tmp/luxyai-effectiveness-state.json

# ---------- Agent 内部通信 ----------
HEALING_AGENT_URL=http://localhost:8101/a2a/tasks
INCIDENT_AGENT_URL=http://localhost:8102/a2a/tasks
POSTMORTEM_AGENT_URL=http://localhost:8103/a2a/tasks
OBSERVABILITY_AGENT_URL=http://localhost:8100

# ---------- MCP Server ----------
MCP_SERVER_URL=http://localhost:8105/mcp

# ---------- 日志 ----------
LOG_LEVEL=INFO
# ---------- 控制台管理员（密码不得写入本文件或 ConfigMap） ----------
CONSOLE_AUTH_REQUIRED=false
CONSOLE_ADMIN_MODE=false
CONSOLE_ADMIN_USERS=admin
CONSOLE_ADMIN_TRUSTED_IDENTITY=false
# CONSOLE_BASIC_AUTH_USERNAME / CONSOLE_BASIC_AUTH_PASSWORD 必须由 Kubernetes Secret 注入。
